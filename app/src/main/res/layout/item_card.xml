<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    app:cardCornerRadius="15dp"
    app:cardBackgroundColor="@color/beige_card"
    app:strokeColor="@color/gold_light"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <TextView
            android:id="@+id/tvCardType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="آية قرانية"
            android:textColor="@color/gold_mustard"
            android:textSize="12sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvCardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="نص المحتوى سيظهر هنا بشكل أنيق..."
            android:textColor="@color/text_dark"
            android:textSize="18sp"
            android:lineSpacingExtra="5dp"
            android:gravity="right"/>

        <TextView
            android:id="@+id/tvCardSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="[سورة البقرة]"
            android:textColor="@color/olive_primary"
            android:textSize="14sp"
            android:gravity="left"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
